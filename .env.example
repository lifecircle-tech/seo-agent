# DATABASE
DATABASE_URL=mysql://root:@localhost:3306/seo_agent         # Local MySQL connection string; replace with your own
LC_DATABASE_URL= mysql://root:@localhost:3306/lifecirclefamily

# ── Malti Backend ─────────────────────────────────────────────────────────
# lifecircle_pulse DB (campaigns, contacts, contact_registry)
PULSE_DATABASE_URL=mysql://root:@localhost:3306/lifecirclefamily
# Legacy LifeCircle DB (life_emp_details, n_care_jobs_leads, n_bolna_activity_log)
LEGACY_DATABASE_URL=mysql://root:@localhost:3306/lifecirclefamily

# Dashboard
DASHBOARD_URL= http://localhost:3001        # URL where the dashboard frontend is running
BACKEND_API_URL=http://localhost:3002       # URL where the backend API is running (your current server)

# JWT auth
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Anthropic
# Claude AI
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-5

# Google
GOOGLE_API_KEY=         # Google API KEY
GSC_OAUTH_SITE=         # Google service account JSON for Search Console API
GBP_OAUTH_SITE=         # Google service account JSON for Business Profile API
GBP_CLIENT_ID=          # Google client ID for Business Profile API
GBP_CLIENT_SECRET=      # Google client secret for Business Profile API
ADS_ACCOUNT_SITE=       # Google Ads account ID
GOOGLE_ADS_TOKEN=       # Google Developer Token

# SEO APIs
AHREFS_KEY=
SERPAPI_KEY=
BING_WEBMASTER_KEY=

# CMS — one per site
CMS_API_URL_SITE_1=     # e.g. https://example.in/wp-json/wp/v2
CMS_API_KEY_SITE_1=     # WordPress application password

# Notifications
SLACK_BOT_TOKEN=        # Slack bot token for sending notifications
SLACK_CHANNEL_ID=       # Slack channel ID to post notifications to
SLACK_WEBHOOK_DB_APPROVALS=https://hooks.slack.com/services/...
SLACK_WEBHOOK_WAR_ROOM=https://hooks.slack.com/services/...

# Google Sheets
SHEETS_ID=              # The spreadsheet ID from the URL

# WhatsApp (Interakt)
INTERAKT_API_KEY=...

# Email / SMTP (AWS SES)
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=465
SMTP_USER=...
SMTP_PASS=...
EMAIL_FROM=ai@lifecircle.in
EMAIL_FROM_NAME=LifeCircle AI

# Google
GOOGLE_CLIENT_ID=...
GCLOUD_TTS_API_KEY=...

# Ollama
OLLAMA_MODEL=

# Ozonetel (voice webhooks)
OZONETEL_WEBHOOK_SECRET=...

# Bolna AI
BOLNA_API_KEY=...
BOLNA_AGENT_ID=...

# Vapi AI
VAPI_API_KEY=...
VAPI_PHONE_NUMBER_ID=...

# Care Jobs
CARE_JOBS_CALL_WINDOW_START=9
CARE_JOBS_CALL_WINDOW_END=21
CARE_JOBS_WHATSAPP_TEMPLATE=care_jobs_app_download
